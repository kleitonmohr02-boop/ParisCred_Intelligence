# ParisCred Intelligence - Environment Variables
# Copie este arquivo para .env e configure segundo seu ambiente

# ========== FLASK ==========
FLASK_ENV=production
FLASK_APP=app.py
SECRET_KEY=seu_secret_key_muito_seguro_aqui

# ========== BANCO DE DADOS ==========
# SQLite (desenvolvimento): DATABASE_URL vazio ou sqlite:///app.db
# PostgreSQL (produção NeonDB): postgresql://user:password@host/dbname
DATABASE_PATH=app.db
DATABASE_URL=

# ========== APIs ==========
# Google Gemini AI (opcional)
GEMINI_API_KEY=

# ========== SEGURANÇA ==========
CORS_ORIGINS=http://localhost:5000,https://pariscred-intelligence.onrender.com

# ========== LOGS ==========
LOG_LEVEL=INFO
LOG_FILE=logs/pariscred.log
