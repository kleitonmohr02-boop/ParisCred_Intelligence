# ParisCred Intelligence - Variáveis de Ambiente
# Copie este arquivo para .env e configure segundo seu ambiente

# ========== FLASK ==========
FLASK_ENV=production
FLASK_APP=app_novo.py
SECRET_KEY=seu_secret_key_muito_seguro_aqui

# ========== BANCO DE DADOS ==========
DATABASE_PATH=app.db
DATABASE_URL=sqlite:///app.db

# ========== EVOLUTION API (WhatsApp) ==========
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=CONSIGNADO123
EVOLUTION_INSTANCE_NAME=Paris_01

# ========== POSTGRESQL (opcional para Evolution) ==========
POSTGRES_USER=evolution
POSTGRES_PASSWORD=sua_senha_postgres
POSTGRES_DB=evolution
DATABASE_CONNECTION_URI=postgresql://evolution:sua_senha_postgres@localhost:5432/evolution

# ========== REDIS ==========
REDIS_URI=redis://localhost:6379

# ========== GOOGLE CLOUD ==========
GCP_PROJECT_ID=seu-projeto-gcp
GCP_BUCKET_NAME=pariscred-backups
GCP_REGION=us-central1

# ========== EMAIL (Notificações) ==========
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=seu_email@gmail.com
MAIL_PASSWORD=sua_senha_app
ADMIN_EMAIL=admin@pariscred.com

# ========== SEGURANÇA ==========
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ========== LOGS ==========
LOG_LEVEL=INFO
LOG_FILE=logs/pariscred.log

# ========== CACHE ==========
CACHE_TYPE=redis
CACHE_REDIS_URL=redis://localhost:6379/1
CACHE_DEFAULT_TIMEOUT=300
